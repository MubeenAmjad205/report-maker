# GitHub Configuration
# Personal Access Token (classic) with 'repo' scope. Required to read private repositories.
GH_PAT=ghp_your_personal_access_token_here
# Your GitHub Username
GITHUB_USERNAME=your_github_username

# AI Configuration
# Options: GEMINI, OPENAI, OPENROUTER
AI_PROVIDER=OPENROUTER
# The specific model to use (e.g., anthropic/claude-3.5-sonnet, google/gemini-flash-1.5)
AI_MODEL=google/gemini-flash-1.5
# The API key for your chosen provider
AI_API_KEY=your_ai_api_key_here

# Telegram / Notification Configuration
# (Optional if using MS Teams) Bot token obtained from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# (Optional if using MS Teams) The Chat ID to send the report to.
TELEGRAM_CHAT_ID=your_telegram_chat_id

# MS Teams Configuration
# (Optional if using Telegram) The Incoming Webhook URL for your MS Teams channel
MSTEAMS_WEBHOOK_URL=https://your-domain.webhook.office.com/webhookb2/...
